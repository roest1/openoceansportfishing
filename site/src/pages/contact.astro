---
import Base from "../layouts/Base.astro";

const web3formsKey = import.meta.env.PUBLIC_WEB3FORMS_KEY ?? "YOUR_WEB3FORMS_KEY";
---

<Base
  title="Contact — Open Ocean Sportfishing | Marco Island, FL"
  description="Get in touch with Open Ocean Sportfishing in Marco Island, Florida. Call or text Captain Jon at 239-293-6137 or send us a message."
>
  <section class="bg-white py-20 md:py-28">
    <div class="mx-auto max-w-6xl px-4 md:px-8">
      <p class="text-center font-display text-sm uppercase tracking-[0.4em] text-seafoam">Reach Out</p>
      <h1 class="mt-3 text-center text-5xl uppercase text-seafoam md:text-7xl">
        Contact Us!
      </h1>

      <div class="mt-14 grid gap-0 overflow-hidden rounded-2xl shadow-xl md:grid-cols-[5fr_7fr]">
        <div class="bg-navy p-8 text-cream md:p-12">
          <p class="text-2xl leading-relaxed text-cream md:text-3xl">
            We are here to help, please reach out with any questions and we will get back to you!
          </p>

          <div class="mt-10 space-y-5">
            <p class="text-lg">
              <span class="block text-xs uppercase tracking-[0.3em] text-cream/60">Call or Text</span>
              <a href="tel:+12392936137" class="mt-1 inline-block text-2xl font-semibold text-cream hover:text-seafoam md:text-3xl">
                239-293-6137
              </a>
            </p>
            <p class="text-lg">
              <span class="block text-xs uppercase tracking-[0.3em] text-cream/60">Email</span>
              <a href="mailto:openoceansportfishing@gmail.com" class="mt-1 inline-block break-all text-base font-semibold text-cream hover:text-seafoam md:text-lg">
                openoceansportfishing@gmail.com
              </a>
            </p>
            <p class="text-lg">
              <span class="block text-xs uppercase tracking-[0.3em] text-cream/60">Where</span>
              <span class="mt-1 inline-block text-base text-cream md:text-lg">Marco Island, Florida</span>
            </p>
          </div>
        </div>

        <div class="bg-cream p-8 md:p-12">
          <form id="contact-form" class="space-y-5" novalidate>
            <input type="hidden" name="access_key" value={web3formsKey} />
            <input type="hidden" name="subject" value="[Open Ocean Sportfishing] Website inquiry" />
            <input type="hidden" name="from_name" value="openoceansportfishing.com" />
            <input type="text" name="botcheck" class="hidden" tabindex="-1" autocomplete="off" />

            <div>
              <label for="name" class="block text-xs font-semibold uppercase tracking-[0.2em] text-navy">
                Name <span class="text-seafoam">*</span>
              </label>
              <input
                id="name"
                name="name"
                type="text"
                required
                autocomplete="name"
                class="mt-2 w-full rounded-md border border-navy/20 bg-white px-4 py-3 text-base text-navy placeholder-slate focus:border-seafoam focus:outline-none focus:ring-2 focus:ring-seafoam/40"
              />
            </div>

            <div>
              <label for="phone" class="block text-xs font-semibold uppercase tracking-[0.2em] text-navy">
                Phone <span class="text-seafoam">*</span>
              </label>
              <input
                id="phone"
                name="phone"
                type="tel"
                required
                autocomplete="tel"
                class="mt-2 w-full rounded-md border border-navy/20 bg-white px-4 py-3 text-base text-navy placeholder-slate focus:border-seafoam focus:outline-none focus:ring-2 focus:ring-seafoam/40"
              />
            </div>

            <div>
              <label for="email" class="block text-xs font-semibold uppercase tracking-[0.2em] text-navy">
                Email <span class="text-seafoam">*</span>
              </label>
              <input
                id="email"
                name="email"
                type="email"
                required
                autocomplete="email"
                class="mt-2 w-full rounded-md border border-navy/20 bg-white px-4 py-3 text-base text-navy placeholder-slate focus:border-seafoam focus:outline-none focus:ring-2 focus:ring-seafoam/40"
              />
            </div>

            <div>
              <label for="message" class="block text-xs font-semibold uppercase tracking-[0.2em] text-navy">
                Message <span class="text-seafoam">*</span>
              </label>
              <textarea
                id="message"
                name="message"
                rows="5"
                required
                class="mt-2 w-full rounded-md border border-navy/20 bg-white px-4 py-3 text-base text-navy placeholder-slate focus:border-seafoam focus:outline-none focus:ring-2 focus:ring-seafoam/40"
              ></textarea>
            </div>

            <button
              type="submit"
              id="contact-submit"
              class="w-full rounded-full bg-seafoam px-6 py-3 text-sm font-bold uppercase tracking-widest text-white shadow-md transition-colors hover:bg-navy disabled:opacity-60"
            >
              Submit
            </button>
            <p id="contact-status" class="text-center text-sm" role="status" aria-live="polite"></p>
          </form>
        </div>
      </div>
    </div>
  </section>
</Base>

<script>
  const form = document.getElementById("contact-form") as HTMLFormElement | null;
  const status = document.getElementById("contact-status") as HTMLParagraphElement | null;
  const submitBtn = document.getElementById("contact-submit") as HTMLButtonElement | null;

  if (form && status && submitBtn) {
    form.addEventListener("submit", async (event) => {
      event.preventDefault();
      status.textContent = "Sending...";
      status.className = "text-center text-sm text-slate";
      submitBtn.disabled = true;

      const formData = new FormData(form);
      const accessKey = formData.get("access_key");

      if (!accessKey || accessKey === "YOUR_WEB3FORMS_KEY") {
        status.textContent =
          "Form not configured yet — please call or text 239-293-6137 to reach Captain Jon directly.";
        status.className = "text-center text-sm text-navy font-semibold";
        submitBtn.disabled = false;
        return;
      }

      try {
        const response = await fetch("https://api.web3forms.com/submit", {
          method: "POST",
          body: formData,
        });
        const data = await response.json();
        if (response.ok && data.success) {
          form.reset();
          status.textContent = "Thank you for reaching out! We will contact you soon.";
          status.className = "text-center text-sm text-navy font-semibold";
        } else {
          throw new Error(data.message || "Submission failed");
        }
      } catch (err) {
        status.textContent =
          "Something went wrong. Please call or text 239-293-6137 to reach Captain Jon directly.";
        status.className = "text-center text-sm text-navy font-semibold";
      } finally {
        submitBtn.disabled = false;
      }
    });
  }
</script>
