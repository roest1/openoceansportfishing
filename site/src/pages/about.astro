---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";
import catamaranImg from "../assets/images/about-catamaran.jpg";
import fishingImg from "../assets/images/about-fishing.jpg";

const bookingUrl = "https://fishingbooker.com/charters/view/27547";
---

<Base
  title="About Us — Open Ocean Sportfishing | Marco Island, FL"
  description="Aboard the Double Trouble, a 2020 Twin Vee 31′ Catamaran with twin Suzuki 300HP outboards. Sportfish for Wahoo, Sailfish, Tuna, Mahi, Marlin and more out of Marco Island, Florida."
>
  {/* Background loop: aerial ocean waves, "Drone Footage of Ocean Waves" by Rachel Claire on Pexels — free for commercial use, no attribution required. */}
  <section class="relative isolate flex min-h-[32vh] items-center justify-center overflow-hidden bg-navy text-white md:min-h-[38vh]">
    <video
      class="absolute inset-0 h-full w-full object-cover"
      autoplay
      muted
      loop
      playsinline
      preload="metadata"
      poster="/video/about-hero-poster.jpg"
      aria-hidden="true"
    >
      <source src="/video/about-hero.mp4" type="video/mp4" />
    </video>
    <div class="absolute inset-0 bg-gradient-to-b from-navy/75 via-navy/50 to-navy/80" aria-hidden="true"></div>
    <div class="relative z-10 mx-auto max-w-5xl px-4 py-10 text-center md:px-8 md:py-14">
      <p class="font-display text-sm uppercase tracking-[0.4em] text-seafoam">About Us</p>
      <h1 class="mt-3 text-4xl uppercase text-white drop-shadow-lg md:text-6xl">
        Open Ocean Sportfishing
      </h1>
    </div>
  </section>

  <section class="bg-cream py-12 md:py-16">
    <div class="mx-auto max-w-7xl px-4 md:px-8 lg:max-w-[88rem]">
      <div class="grid items-stretch gap-0 overflow-hidden rounded-2xl bg-white shadow-xl md:grid-cols-[58%_42%]">
        <Image
          src={catamaranImg}
          alt="2020 Twin Vee 31′ Catamaran — the Double Trouble"
          widths={[640, 960, 1280, 1600]}
          sizes="(max-width: 768px) 100vw, 58vw"
          class="h-72 w-full object-cover md:h-[480px]"
        />
        <div class="flex flex-col justify-center p-8 md:p-14">
          <h2 class="text-2xl text-navy uppercase tracking-widest md:text-3xl">
            2020 Twin Vee 31′ Catamaran
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-navy/80 md:text-xl">
            The Twin Vee is one of the most versatile offshore and deep sea fishing platforms on the
            water. It is powered by two Suzuki 300HP outboard motors and offers an unparalleled
            stable ride.
          </p>
        </div>
      </div>
    </div>
  </section>

  <section class="bg-cream pb-12 md:pb-16">
    <div class="mx-auto max-w-7xl px-4 md:px-8 lg:max-w-[88rem]">
      <div class="grid items-stretch gap-0 overflow-hidden rounded-2xl bg-navy text-cream shadow-xl md:grid-cols-[42%_58%]">
        <div class="order-2 flex flex-col justify-center p-8 md:order-1 md:p-14">
          <h2 class="text-center text-2xl uppercase tracking-widest text-cream md:text-3xl">
            Fishing
          </h2>
          <p class="mt-5 text-lg leading-relaxed text-cream/90 md:text-xl">
            We get our clients on a variety of sportfish including Wahoo, Sailfish, Tuna, Swordfish,
            Snapper, Dorado (Mahi Mahi), Blue Marlin, etc. Each fish species requires a different
            technique to catch them and we will share our knowledge about baiting, tackle, seasons
            and more as we love to educate our passengers!
          </p>
        </div>
        <Image
          src={fishingImg}
          alt="Offshore catch — sailfish, mahi, tuna"
          widths={[640, 960, 1280, 1600]}
          sizes="(max-width: 768px) 100vw, 58vw"
          class="order-1 h-72 w-full object-cover md:order-2 md:h-[480px]"
        />
      </div>
    </div>
  </section>

  <section class="bg-navy py-12 text-cream md:py-16">
    <div class="mx-auto max-w-3xl px-4 text-center md:px-8">
      <h2 class="text-4xl uppercase text-cream md:text-5xl">
        <span class="font-bold">Book </span>Your Fishing Trip Now!
      </h2>
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="mt-10 inline-block rounded-full bg-white px-10 py-4 text-sm font-bold uppercase tracking-widest text-seafoam shadow-xl transition-colors hover:bg-seafoam hover:text-white"
      >
        Click Here to Book
      </a>
    </div>
  </section>
</Base>
