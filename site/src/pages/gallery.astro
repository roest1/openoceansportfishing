---
import { Image } from "astro:assets";
import Base from "../layouts/Base.astro";

const photoModules = import.meta.glob<{ default: ImageMetadata }>(
  "../assets/images/gallery/*.jpg",
  { eager: true },
);

const speciesLabels: Record<string, string> = {
  "mahi-mahi": "Mahi Mahi",
  sailfish: "Sailfish",
  tuna: "Tuna",
  wahoo: "Wahoo",
  snapper: "Snapper",
  marlin: "Marlin",
  kingfish: "Kingfish",
  swordfish: "Swordfish",
  cobia: "Cobia",
  grouper: "Grouper",
  "red-grouper": "Red Grouper",
  "goliath-grouper": "Goliath Grouper",
  snook: "Snook",
  tripletail: "Tripletail",
  redfish: "Redfish",
  "dock-catch": "Day's catch at the dock",
  catamaran: "Twin Vee 31′ catamaran",
  sunset: "Marco Island sunset",
  crew: "Open Ocean Sportfishing crew",
  "double-trouble": "Aboard the Double Trouble",
  release: "Release",
  reeling: "Hooked up",
};

function altFromFilename(path: string): string {
  const file = path.split("/").pop()?.replace(/\.[^.]+$/, "") ?? "";
  const base = file.replace(/-\d+$/, "");
  const label = speciesLabels[base];
  if (label) {
    return `${label} — Open Ocean Sportfishing charter out of Marco Island, FL`;
  }
  return `Catch from an Open Ocean Sportfishing charter out of Marco Island, FL`;
}

const photos = Object.entries(photoModules)
  .sort(([a], [b]) => a.localeCompare(b))
  .map(([path, mod], index) => ({
    src: mod.default,
    alt: altFromFilename(path),
    index,
  }));
---

<Base
  title="Photo Gallery — Open Ocean Sportfishing | Marco Island, FL"
  description="Recent catches and trips aboard the Double Trouble — Wahoo, Sailfish, Tuna, Mahi Mahi and more from Marco Island, Florida charters."
>
  <section class="bg-white py-20 md:py-28">
    <div class="mx-auto max-w-7xl px-4 md:px-8">
      <p class="text-center font-display text-sm uppercase tracking-[0.4em] text-seafoam">Trophy Room</p>
      <h1 class="mt-3 text-center text-5xl uppercase text-seafoam md:text-7xl">
        Photo Gallery
      </h1>
      <p class="mx-auto mt-5 max-w-xl text-center text-base text-slate">
        A look at recent trips out of Marco Island. Click any photo to view full size.
        {/* TODO: replace with fresh Marco Island photos when Jon delivers new shots */}
      </p>

      <div class="mt-12 grid grid-cols-2 gap-3 sm:grid-cols-3 md:gap-4 lg:grid-cols-4">
        {photos.map((photo) => (
          <button
            type="button"
            class="group relative aspect-square overflow-hidden rounded-lg bg-cream shadow-sm ring-1 ring-black/5 transition-shadow hover:shadow-xl"
            data-lightbox-index={photo.index}
          >
            <Image
              src={photo.src}
              alt={photo.alt}
              widths={[320, 480, 640]}
              sizes="(max-width: 640px) 50vw, (max-width: 1024px) 33vw, 25vw"
              loading={photo.index < 2 ? "eager" : "lazy"}
              fetchpriority={photo.index === 0 ? "high" : "auto"}
              decoding="async"
              class="absolute inset-0 h-full w-full object-cover transition-transform duration-500 group-hover:scale-110"
            />
            <span class="sr-only">View photo {photo.index + 1}</span>
          </button>
        ))}
      </div>
    </div>
  </section>

  <dialog
    id="lightbox"
    class="bg-transparent p-0 backdrop:bg-black/85 backdrop:backdrop-blur-sm"
    aria-label="Photo lightbox"
  >
    <div class="relative flex h-screen w-screen items-center justify-center p-4">
      <button
        type="button"
        id="lightbox-close"
        class="absolute right-4 top-4 z-10 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-navy shadow-lg transition-colors hover:bg-white"
        aria-label="Close"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="18" y1="6" x2="6" y2="18"></line>
          <line x1="6" y1="6" x2="18" y2="18"></line>
        </svg>
      </button>
      <button
        type="button"
        id="lightbox-prev"
        class="absolute left-4 z-10 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-navy shadow-lg transition-colors hover:bg-white"
        aria-label="Previous photo"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="15 18 9 12 15 6"></polyline>
        </svg>
      </button>
      <button
        type="button"
        id="lightbox-next"
        class="absolute right-4 z-10 inline-flex h-12 w-12 items-center justify-center rounded-full bg-white/90 text-navy shadow-lg transition-colors hover:bg-white"
        aria-label="Next photo"
        style="right: 5rem;"
      >
        <svg width="24" height="24" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <polyline points="9 18 15 12 9 6"></polyline>
        </svg>
      </button>
      <img id="lightbox-img" src="" alt="" class="max-h-full max-w-full object-contain" />
    </div>
  </dialog>
</Base>

<script>
  const photoData: { src: string; alt: string }[] = Array.from(
    document.querySelectorAll<HTMLButtonElement>("button[data-lightbox-index]"),
  ).map((btn) => {
    const img = btn.querySelector("img") as HTMLImageElement;
    return { src: img.currentSrc || img.src, alt: img.alt };
  });

  const dialog = document.getElementById("lightbox") as HTMLDialogElement;
  const lightboxImg = document.getElementById("lightbox-img") as HTMLImageElement;
  const closeBtn = document.getElementById("lightbox-close") as HTMLButtonElement;
  const prevBtn = document.getElementById("lightbox-prev") as HTMLButtonElement;
  const nextBtn = document.getElementById("lightbox-next") as HTMLButtonElement;
  let currentIndex = 0;

  function show(index: number) {
    currentIndex = (index + photoData.length) % photoData.length;
    const photo = photoData[currentIndex];
    lightboxImg.src = photo.src;
    lightboxImg.alt = photo.alt;
  }

  document.querySelectorAll<HTMLButtonElement>("button[data-lightbox-index]").forEach((btn) => {
    btn.addEventListener("click", () => {
      const idx = parseInt(btn.dataset.lightboxIndex || "0", 10);
      show(idx);
      dialog.showModal();
    });
  });

  closeBtn.addEventListener("click", () => dialog.close());
  prevBtn.addEventListener("click", () => show(currentIndex - 1));
  nextBtn.addEventListener("click", () => show(currentIndex + 1));

  dialog.addEventListener("click", (e) => {
    if (e.target === dialog) dialog.close();
  });

  document.addEventListener("keydown", (e) => {
    if (!dialog.open) return;
    if (e.key === "ArrowLeft") show(currentIndex - 1);
    if (e.key === "ArrowRight") show(currentIndex + 1);
  });
</script>
