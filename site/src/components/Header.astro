---
const pathname = Astro.url.pathname.replace(/\/$/, "") || "/";

const nav = [
  { href: "/", label: "Home" },
  { href: "/about", label: "About" },
  { href: "/trips", label: "Trips" },
  { href: "/faq", label: "FAQ" },
  { href: "/gallery", label: "Gallery" },
  { href: "/contact", label: "Contact" },
];

const bookingUrl = "https://fishingbooker.com/charters/view/27547";
---

<header class="sticky top-0 z-50 w-full bg-white text-navy shadow-sm">
  <div class="mx-auto flex max-w-7xl items-center justify-end gap-4 px-4 py-3 md:px-8">
    <nav class="hidden md:flex items-center gap-7" aria-label="Primary">
      {nav.map((item) => (
        <a
          href={item.href}
          class:list={[
            "text-sm font-bold uppercase tracking-wider transition-colors text-navy hover:text-seafoam",
            pathname === item.href && "text-seafoam",
          ]}
        >
          {item.label}
        </a>
      ))}
      <a
        href={bookingUrl}
        target="_blank"
        rel="noopener noreferrer"
        class="rounded-full bg-seafoam px-5 py-2 text-sm font-bold uppercase tracking-wider text-white shadow-md transition-colors hover:bg-navy"
      >
        Book Now
      </a>
    </nav>

    <details class="md:hidden relative">
      <summary
        class="list-none cursor-pointer rounded-md p-2 text-navy transition-colors"
        aria-label="Open menu"
      >
        <svg xmlns="http://www.w3.org/2000/svg" width="28" height="28" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="2.5" stroke-linecap="round" stroke-linejoin="round" aria-hidden="true">
          <line x1="3" y1="6" x2="21" y2="6"></line>
          <line x1="3" y1="12" x2="21" y2="12"></line>
          <line x1="3" y1="18" x2="21" y2="18"></line>
        </svg>
      </summary>
      <div class="absolute right-0 top-full mt-2 w-56 rounded-lg bg-white p-3 shadow-xl ring-1 ring-black/10">
        <nav class="flex flex-col gap-1" aria-label="Mobile">
          {nav.map((item) => (
            <a
              href={item.href}
              class:list={[
                "block rounded-md px-3 py-2 text-sm font-semibold uppercase tracking-wider text-navy hover:bg-cream",
                pathname === item.href && "bg-cream text-seafoam",
              ]}
            >
              {item.label}
            </a>
          ))}
          <a
            href={bookingUrl}
            target="_blank"
            rel="noopener noreferrer"
            class="mt-2 block rounded-md bg-seafoam px-3 py-2 text-center text-sm font-bold uppercase tracking-wider text-white hover:bg-navy"
          >
            Book Now
          </a>
        </nav>
      </div>
    </details>
  </div>
</header>

<style>
  details > summary::-webkit-details-marker { display: none; }
  details[open] > summary svg line:nth-child(1) { transform: rotate(45deg) translate(0, 8px); }
  details[open] > summary svg line:nth-child(2) { opacity: 0; }
  details[open] > summary svg line:nth-child(3) { transform: rotate(-45deg) translate(0, -8px); }
  details > summary svg line { transition: transform 0.2s ease, opacity 0.2s ease; transform-origin: center; }
</style>
